# MF910L SMS Forwarder config
# Copy to /data/sms_forward.env on the router and fill values.

# Webhook receiving POST JSON
WEBHOOK_URL="https://your-n8n-host.example.com/webhook/sms-gateway"

# Router admin password, base64-encoded
# printf 'YourPass' | base64
PASS_B64=""

# ---- Optional: paths ----
# CURL="/data/curl"
# SEEN="/data/sms_forwarded_ids.txt"
# RETRY_FILE="/data/sms_retry.txt"
# STATS_FILE="/data/sms_stats.txt"
# LOG="/data/sms_forward.log"
# INTERVAL=30
# API="http://127.0.0.1"

# ---- Rotation caps (lines) ----
# SEEN_MAX=1000
# SEEN_KEEP=500
# LOG_MAX=2000
# LOG_KEEP=1000

# ---- Session refresh (iterations; 0 = off). 60 * 30s = 30min ----
# RELOGIN_EVERY=60

# ---- SMS storage to poll ----
# "1"=SIM, "0"=module memory. Space-separated. Poll both by default.
# MEM_STORES="1 0"

# ---- Delete SMS from router after successful forward (1/0) ----
# Keeps bandeja empty so router keeps accepting new SMS.
# DELETE_AFTER_FORWARD=1

# ---- Retry cap per message before giving up ----
# On webhook failure SMS stays unread on router and retries each poll.
# After MAX_RETRIES failures the ID is marked seen, logged, and skipped.
# MAX_RETRIES=5

# ---- HMAC-SHA256 signing (optional) ----
# If set AND openssl exists on router, adds: X-Signature: sha256=<hex>
# Receiver verifies by computing HMAC-SHA256(secret, raw_body).
# HMAC_SECRET=""
