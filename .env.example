# MF910L SMS Forwarder config
# Copy to /data/sms_forward.env on the router and fill values.

# n8n (or any) webhook receiving POST JSON
WEBHOOK_URL="https://your-n8n-host.example.com/webhook/sms-gateway"

# Router admin password, base64-encoded
# printf 'YourPass' | base64
PASS_B64=""

# Optional overrides (defaults shown)
# CURL="/data/curl"
# SEEN="/data/sms_forwarded_ids.txt"
# LOG="/data/sms_forward.log"
# INTERVAL=30
# API="http://127.0.0.1"

# Rotation caps (lines). Avoid /data fill-up on long uptime.
# SEEN_MAX=1000
# SEEN_KEEP=500
# LOG_MAX=2000
# LOG_KEEP=1000

# Periodic session refresh (iterations). 60 iters * 30s = 30min.
# Set 0 to disable.
# RELOGIN_EVERY=60
